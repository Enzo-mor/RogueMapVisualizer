<Window x:Class="RogueMapVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Procedural Map Generator"
        Height="700"
        Width="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBlock Text="MinWidth" Margin="5"/>
            <TextBox x:Name="minWidthBox" Width="50" Text="5" Margin="5"/>

            <TextBlock Text="MaxWidth" Margin="5"/>
            <TextBox x:Name="maxWidthBox" Width="50" Text="8" Margin="5"/>

            <TextBlock Text="MinHeight" Margin="5"/>
            <TextBox x:Name="minHeightBox" Width="50" Text="5" Margin="5"/>

            <TextBlock Text="MaxHeight" Margin="5"/>
            <TextBox x:Name="maxHeightBox" Width="50" Text="8" Margin="5"/>

            <TextBlock Text="minMinus" Margin="5"/>
            <TextBox x:Name="minMinusBox" Width="50" Text="15" Margin="5"/>

            <TextBlock Text="maxMinus" Margin="5"/>
            <TextBox x:Name="maxMinusBox" Width="50" Text="20" Margin="5"/>

            <TextBlock Text="Seed" Margin="5"/>
            <TextBox x:Name="seedBox" Width="100" Text="0" Margin="5"/>

            <CheckBox x:Name="showRoomsCheck" Content="Show Rooms" IsChecked="True" Margin="10" Checked="DisplayOptionsChanged" Unchecked="DisplayOptionsChanged"/>
            <CheckBox x:Name="showWallsCheck" Content="Show Walls" IsChecked="True" Margin="10"/>
            <CheckBox x:Name="showClustersCheck" Content="Show Clusters" IsChecked="True" Margin="10" Checked="DisplayOptionsChanged" Unchecked="DisplayOptionsChanged"/>

            <Button Content="Generate Map" Click="GenerateMap" Margin="10"/>

            <Button Content="Previous" Click="PreviousStep" Margin="5"/>
            <Button Content="Next" Click="NextStep" Margin="5"/>

            <TextBlock x:Name="stepTextBlock" Margin="10,5" VerticalAlignment="Center" Text="Step : 0 / 0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Canvas x:Name="MapCanvas" Background="LightGray" Height="625"/>
        </ScrollViewer>
    </Grid>
</Window>